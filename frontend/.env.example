# Base URL of the SocialReviewCard .NET backend.
# Leave empty to use the Vite dev proxy (see vite.config.ts).
# In production set it to your API origin, e.g. https://api.socialreviewcard.com
VITE_API_BASE=

# Google OAuth 2.0 Web Client ID (from Google Cloud Console → Credentials).
# Must list your frontend origin under "Authorized JavaScript origins",
# e.g. http://localhost:5173 and https://socialreviewcard.com
VITE_GOOGLE_CLIENT_ID=330696130362-k2rkcbn5skuvloqan21d8snn4c9tl01n.apps.googleusercontent.com
